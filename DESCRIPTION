Package: imageseg
Type: Package
Title: Deep Learning Models for Image Segmentation
Version: 0.5.2
Authors@R: c(
            person("Juergen", "Niedballa", email = "camtrapr@gmail.com", role = c("aut", "cre"),
                   comment = c(ORCID = "0000-0002-9187-2116")),
